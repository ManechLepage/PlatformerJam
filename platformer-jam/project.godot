;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="PlatformerJam"
config/tags=PackedStringArray("2d", "game", "pixel_art", "platformer")
run/main_scene="uid://b1a3pis82gmoo"
config/features=PackedStringArray("4.7", "Forward Plus")
run/max_fps=120
run/stretch/scale_mode="integer"
run/size/mode=0

[audio]

buses/default_bus_layout="uid://bxo5p27e5q5w4"
general/default_playback_type.web=0
general/physics_interpolation=true

[autoload]

Game="*uid://ces3yepxa2r0n"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/size/mode=2
window/size/sharp_corners=true
window/size/window_width_override=960
window/size/window_height_override=540
window/stretch/mode="viewport"

[file_customization]

folder_colors={
"res://Resources/": "green",
"res://Scenes/": "teal",
"res://Scripts/": "blue"
}

[global_group]

