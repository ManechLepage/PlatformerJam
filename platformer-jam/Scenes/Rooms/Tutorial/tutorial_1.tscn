[sub_resource type="RectangleShape2D" id="RectangleShape2D_5khlg"]

[sub_resource type="GDScript" id="GDScript_04iir"]
resource_name = "intro_controller"
script/source = "extends CanvasLayer

@export var animation : AnimationPlayer

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	if Game.seen_intro: 
		hide()
	else:
		Game.seen_intro = true
		Game.player.process_mode = Node.PROCESS_MODE_DISABLED
		animation.animation_finished.connect(anim_done)
	
func anim_done(anim):
	match anim:
		\"start\":
			animation.play(\"start_loop\")
		\"start_2\":
			animation.play(\"start_loop_2\")
		\"start_3\":
			animation.play(\"start_loop_3\")


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _input(event: InputEvent) -> void:
	if Input.is_action_just_pressed(\"intro_continue\"):
		match animation.current_animation:
			\"start_loop\":
				animation.play(\"start_2\")
			\"start_loop_2\":
				animation.play(\"start_3\")
			\"start_loop_3\":
				animation.play(\"start_4\")
				Game.player.process_mode = Node.PROCESS_MODE_INHERIT
"

