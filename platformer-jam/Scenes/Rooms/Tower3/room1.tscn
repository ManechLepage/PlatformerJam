[sub_resource type="GDScript" id="GDScript_g4v7s"]
resource_name = "gear"
script/source = "extends Node2D

@export var enabled: bool = false
@export var rpm: float = 2
@onready var sprite := $Sprite2D
var tween := 0.0


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	if enabled:
		tween = clamp(tween+ delta,0,1)
		sprite.frame = 1
	else:
		sprite.frame = 0
		tween = clamp(tween- delta,0,1)
	rotation += tween * rpm*delta*60/360
"

