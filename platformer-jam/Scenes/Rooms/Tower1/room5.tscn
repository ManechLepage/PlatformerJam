[node name="PoemText" parent="Offset/Obstacles/Area2/CanvasLayer" parent_id_path=PackedInt32Array(1754253968, 1989050324) index="2" unique_id=1098363463]
offset_left = 126.0
offset_top = -26.0
offset_right = 667.0
offset_bottom = 481.0
grow_horizontal = 1
grow_vertical = 1
text = "\"When I got home after my 3-day vacation at the hospital for a
pneumothorax, my mom told me my grand-parents had sent me
flowers.
They were nice.
But they didn't feel like they belonged to me.
What did I do to deserve flowers? If anything, the doctors and
nurses should be getting bouquets.
Flowers are for successful plays, performances and marriages...
I lingered with that, I felt like that logic was sound.
I didn't consider for a long time that maybe support didn't need to be earned, and it took much longer to truly believe it.
...But, since then, I've never seen flowers the same way.

I will never forget this memory, it defines who I am.\"
[Press C to forget]"

