[sub_resource type="GDScript" id="GDScript_u50mg"]
resource_name = "lucid_mist"
script/source = "extends CanvasLayer

@export var area_start_color1: Color
@export var area_start_color2: Color
@export var area_start_color3: Color
@export var area_1_color1: Color
@export var area_1_color2: Color
@export var area_1_color3: Color
@export var area_2_color1: Color
@export var area_2_color2: Color
@export var area_2_color3: Color
@export var area_3_color1: Color
@export var area_3_color2: Color
@export var area_3_color3: Color
@export var area_4_color1: Color
@export var area_4_color2: Color
@export var area_4_color3: Color
@export var area_bridge1_color1: Color
@export var area_bridge1_color2: Color
@export var area_bridge1_color3: Color
@export var area_bridge2_color1: Color
@export var area_bridge2_color2: Color
@export var area_bridge2_color3: Color

var tweenA: Tween
var tweenB: Tween
var tweenC: Tween

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	Game.event_manager.lucidity_changed.connect(update_lucidity)
	Game.world_env = $\"../WorldEnvironment\"
	$\"lucid bg\".material.set_shader_parameter(\"alpha\",0)
	$\"lucid bg/Overlay/lucid overlay\".material.set_shader_parameter(\"alpha\",0)
	$\"../Areas/Tower1Area\".body_entered.connect(func(_body):change_colors(\"1\"))
	$\"../Areas/Tower2Area\".body_entered.connect(func(_body):change_colors(\"2\"))
	$\"../Areas/Tower3Area\".body_entered.connect(func(_body):change_colors(\"3\"))
	$\"../Areas/Tower4Area\".body_entered.connect(func(_body):change_colors(\"4\"))
	$\"../Areas/BridgeArea1\".body_entered.connect(func(_body):change_colors(\"bridge1\"))
	$\"../Areas/BridgeArea2\".body_entered.connect(func(_body):change_colors(\"bridge2\"))
	change_colors(\"start\")

func change_colors(color_name: String):
	var c:Array[Color] = []
	for tween in [tweenA,tweenB,tweenC]:
		if tween: tween.kill()
	match color_name:
		\"start\":
			c = [area_start_color1,area_start_color2,area_start_color3]
		\"1\":
			c = [area_1_color1,area_1_color2,area_1_color3]
			$\"../MusicManager\".set_pillar_1()
		\"2\":
			c = [area_2_color1,area_2_color2,area_2_color3]
			$\"../MusicManager\".set_pillar_2()
		\"3\":
			c = [area_3_color1,area_3_color2,area_3_color3]
			$\"../MusicManager\".set_pillar_3()
		\"4\":
			c = [area_4_color1,area_4_color2,area_4_color3]
			$\"../MusicManager\".set_pillar_1()
		\"bridge1\":
			c = [area_bridge1_color1,area_bridge1_color2,area_bridge1_color3]
		\"bridge2\":
			c = [area_bridge2_color1,area_bridge2_color2,area_bridge2_color3]
	for i in [$\"lucid bg\",$\"lucid bg/Overlay/lucid overlay\"]:
		tweenA = create_tween()
		tweenA.tween_method(set_shader_colorA,$\"lucid bg\".material.get_shader_parameter(\"colorA\"),c[0],2)
		tweenB = create_tween()
		tweenB.tween_method(set_shader_colorB,$\"lucid bg\".material.get_shader_parameter(\"colorB\"),c[1],2)
		tweenC = create_tween()
		tweenC.tween_method(set_shader_colorC,$\"lucid bg\".material.get_shader_parameter(\"colorC\"),c[2],2)
	
func set_shader_colorA(val):
	$\"lucid bg\".material.set_shader_parameter(\"colorA\",val)

func set_shader_colorB(val):
	$\"lucid bg\".material.set_shader_parameter(\"colorB\",val)

func set_shader_colorC(val):
	$\"lucid bg\".material.set_shader_parameter(\"colorC\",val)
	
func update_lucidity(lucidity):
	
	$\"lucid bg\".material.set_shader_parameter(\"speed\",ease(lucidity/100,5)*5)
	$\"lucid bg/Overlay/lucid overlay\".material.set_shader_parameter(\"speed\",ease(lucidity/100,5)*6)
	$\"lucid bg\".material.set_shader_parameter(\"alpha\",ease(lucidity/100,0.8))
	$\"lucid bg/Overlay/lucid overlay\".material.set_shader_parameter(\"alpha\",ease(lucidity/100,0.8))
	$\"lucid bg/Overlay/CanvasLayer/ColorRect\".material.set_shader_parameter(\"amount\",lucidity/100)
"

