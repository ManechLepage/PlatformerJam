[sub_resource type="GDScript" id="GDScript_2060n"]
resource_name = "FlavorText"
script/source = "extends Control

@export var sub: RichTextLabel
@export var ruins: RichTextLabel
@export var garden: RichTextLabel
@export var currents: RichTextLabel
@export var rythm: RichTextLabel
@export var will: RichTextLabel
var tween: Tween

func show_flavor_text(_body,area: Area2D):
	var text: RichTextLabel
	match area.name:
		\"Tower1Area\":
			text = garden
		\"Tower2Area\":
			text = currents
		\"Tower3Area\":
			text = rythm
		\"Tower3Area\":
			text = will
		\"sub\":
			text = sub
		\"ruins\":
			text = ruins
		_:
			print(area,area.name)
	tween = create_tween()
	tween.tween_property(text,\"modulate:a\",1,0.7)
	tween.tween_property(text,\"modulate:a\",2,2)
	tween.tween_property(text,\"modulate:a\",0,3)
"

